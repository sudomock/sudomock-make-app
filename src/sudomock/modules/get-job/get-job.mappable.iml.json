[
  {
    "name": "job_id",
    "label": "Job ID",
    "type": "uuid",
    "required": true
  },
  {
    "name": "wait_for_completion",
    "label": "Wait for completion",
    "type": "boolean",
    "default": false
  },
  {
    "name": "poll_timeout",
    "label": "Polling timeout",
    "type": "integer",
    "default": 30,
    "validate": {
      "min": 5,
      "max": 30
    },
    "visible": "{{parameters.wait_for_completion}}",
    "help": "Maximum wait within Make's 40-second module limit. For longer jobs, run this module again in a later scenario cycle."
  }
]
