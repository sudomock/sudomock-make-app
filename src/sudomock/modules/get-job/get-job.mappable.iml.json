[
  {
    "name": "job_id",
    "label": "Job ID",
    "type": "uuid",
    "required": true
  },
  {
    "name": "wait_for_completion",
    "label": "Wait for completion",
    "type": "boolean",
    "default": false
  },
  {
    "name": "poll_timeout",
    "label": "Polling timeout",
    "type": "integer",
    "default": 300,
    "validate": {
      "min": 5,
      "max": 300
    },
    "visible": "{{parameters.wait_for_completion}}",
    "help": "Maximum wait in seconds. SudoMock uses Make's extended timeout for long-running video, image, and media-generation jobs."
  }
]
