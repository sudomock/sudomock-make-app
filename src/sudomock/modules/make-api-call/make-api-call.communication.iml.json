{
  "qs": {
    "{{...}}": "{{toCollection(parameters.qs, 'key', 'value')}}"
  },
  "url": "https://api.sudomock.com/{{parameters.url}}",
  "body": "{{parameters.body}}",
  "type": "text",
  "method": "{{parameters.method}}",
  "headers": {
    "{{...}}": "{{toCollection(parameters.headers, 'key', 'value')}}"
  },
  "response": {
    "output": {
      "body": "{{body}}",
      "headers": "{{headers}}",
      "statusCode": "{{statusCode}}"
    }
  }
}
