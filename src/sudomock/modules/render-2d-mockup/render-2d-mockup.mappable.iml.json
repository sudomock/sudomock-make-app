            "label": "Rotation",
            "type": "number",
            "default": 0
          },
          {
            "name": "offset_x",
            "label": "Horizontal offset",
            "type": "number",
            "default": 0
          },
          {
            "name": "offset_y",
            "label": "Vertical offset",
            "type": "number",
            "default": 0
