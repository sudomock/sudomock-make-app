  {
    "name": "export_options",
    "label": "Export options",
    "type": "collection",
    "spec": [
      {
        "name": "image_format",
        "label": "Image format",
        "type": "select",
        "options": [
          {
            "label": "PNG",
            "value": "png"
          },
          {
            "label": "JPG",
            "value": "jpg"
          },
          {
            "label": "WebP",
            "value": "webp"
          }
        ],
        "default": "webp"
      },
      {
        "name": "image_size",
        "label": "Image size",
        "type": "integer",
        "default": 2048,
        "validate": {
          "min": 100,
          "max": 10000
        },
        "help": "Output image size in pixels, from 100 to 10000."
      },
      {
        "name": "quality",
        "label": "Quality",
        "type": "integer",
        "default": 90,
        "validate": {
          "min": 1,
          "max": 100
        }
      },
      {
        "name": "dpi",
        "label": "DPI",
        "type": "integer",
        "validate": {
          "min": 72,
          "max": 2400
        }
      }
