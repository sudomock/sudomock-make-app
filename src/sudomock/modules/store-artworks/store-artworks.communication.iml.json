[
  {
    "response": {
      "valid": {
        "condition": "{{length(parameters.items) > 0 || parameters.preview_url}}",
        "message": "Add at least one artwork item or a preview URL.",
        "type": "DataError"
      }
    }
  },
  {
    "url": "/artworks",
    "method": "POST",
    "body": {
      "mockup_uuid": "{{parameters.mockup_uuid}}",
      "items": "{{parameters.items}}",
      "preview_url": "{{parameters.preview_url}}"
    },
    "response": {
      "output": "{{body}}"
    }
  }
]
