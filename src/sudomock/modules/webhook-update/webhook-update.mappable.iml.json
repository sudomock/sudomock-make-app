  {
    "name": "update_fields",
    "label": "Fields to update",
    "type": "collection",
    "spec": [
      {
        "name": "url",
        "label": "Endpoint URL",
        "type": "url"
      },
      {
        "name": "description",
        "label": "Description",
        "type": "text"
      },
      {
        "name": "enabled",
        "label": "Enabled",
        "type": "select",
        "options": [
          {
            "label": "Enabled",
            "value": true
          },
          {
            "label": "Disabled",
            "value": false
          }
        ],
        "help": "Leave empty to keep the current state."
      }
    ]
  }
